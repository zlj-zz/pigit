        function _pigit_completion;
            set -l response;

            for value in (env pu ru r.rn ra -h c.m bM sete fr pf C.tool S.a -s b.d lo s.a set.e f.u l.s set sl ma report C.theirs pF --dry-run C.d td --create-ignore s.d cF c.o rb.s setl rrn rbi m s.l r.a b.a --list S ws --version rbc update_test fa ia cO --help w --until lc pull i.p rv s.c t.a -t m.s t lp rename f.r rba --widget c.F C lg C.mark s.s Cl --create-config rb r.s ms fp f.p --pick-print --pick m.c rb.a c.empty r --count -i b.m i.a -v c.s Su -l -f add --reverse sd rbm --simple p.tags --pick-alt-screen f.t update_prod l --print rb.c --report p.u --complete S.s ta c i w.S bD i.d ir iR i.u --config --search r.rm p.d r.u cf fm --information c.f m.a b.o i.r C.l w.r t.d f.a m.ff c.R l.c Cd -r push -d fetch rb.m bc wds bd b.v b.c set.g iA rrm --type -p fc rs f.C w.c wR repo f.c bL --commit c.a i.R w.d p Sa r.v m.squash clear open l.o setg S.f wS C.ours wd c.fix r.prune w.check l.g w.stash b.D p.F bl ls cd --path --since rbs sa --issue s.p t.p fC mc w.R f S.u cm set.l p.f l.p c.O ca b -c --dangerous b.M w.s w.ds s --author m.no fu ll f.m i.ds rb.i rm co cmd bm sp=fish_complete COMP_WORDS=(commandline -cp)         COMP_CWORD=(commandline -t) pigit);
                set response $response $value;
            end;

            for completion in $response;
                set -l metadata (string split "," $completion);

                if test $metadata[1] = "dir";
                    __fish_complete_directories $metadata[2];
                else if test $metadata[1] = "file";
                    __fish_complete_path $metadata[2];
                else if test $metadata[1] = "plain";
                    print $metadata[2];
                end;
            end;
        end;

        complete --no-files --command pigit --arguments         "(_pigit_completion)";

# PIGIT cmd picker widget (Ctrl+G)
function __pigit_cmd_widget
    set -l tmpfile (mktemp)
    PIGIT_WIDGET_OUTPUT="$tmpfile" pigit cmd --pick-print < /dev/tty > /dev/tty 2>&1
    if test -s "$tmpfile"
        commandline -r (cat "$tmpfile")
    end
    rm -f "$tmpfile"
end
bind \cg __pigit_cmd_widget

