function _pigit_completion;
    set -l response;

    for value in (env cm m SD wx cR pull cmd --show-commands fr iR iX cF Cl ue --show-part-command bs --complete sd ll bm lc b --simple ls mv --help tx savepd Sd --config --commit RS cf ix ma --since bS mt ld cA push Ru Su pp -t --print mF -f Ra open Si --create-config sl t -r --issue user CT lr wC wr --shell fetch repo email f s p sD --report ws --path lv pt pA add R Co Ca Rl cO iu report mC iD -h fc co bd cd ia wR Rm --util wS bM --version -s fm l1 mS pa rm fu rename CO clear pc -c --count -i bc -p bL -v fb wM Rs --information cr sp Sc --create-ignore l id --reverse Ce fC Ct wD wc --types c --author cs wm iA ta wX ca Rp bl Rx pF --dry-run wd ir pf=fish_complete COMP_WORDS=(commandline -cp)         COMP_CWORD=(commandline -t) pigit);
        set response $response $value;
    end;

    for completion in $response;
        set -l metadata (string split "," $completion);

        if test $metadata[1] = "dir";
            __fish_complete_directories $metadata[2];
        else if test $metadata[1] = "file";
            __fish_complete_path $metadata[2];
        else if test $metadata[1] = "plain";
            print $metadata[2];
        end;
    end;
end;

complete --no-files --command pigit --arguments         "(_pigit_completion)";
