#!/usr/env bash

_pigit_completion(){
  if [[ "${COMP_CWORD}" == "1" ]];then
      COMP_WORD="l Si pc CO push iu --config Ru wM lr --since --create-ignore pf iX ta wd mC ir tx c sl open cr add cf bd cm rm co wC -p mt -f -l --issue p fc iD ia wm lc ls cO cd --simple bS Rs ue wS --reverse sd -t cR wD CT fetch Co cA fu Ra fb wr l1 --search mF pt --complete pp clear Rp m user pa cs pF --pick ll bM sp -r -s s ld cF SD --help --report Ct f wc bs Cl R ws mv sD fC Rl fr --dry-run --list ca --information -v --version Ce --shell pA RS savepd fm Rm pull t Sc iR bc Ca id wx report email bl --print --create-config ix -h -c --count wR -i ma --path rename --type repo Sd mS --commit Rx b lv --author cmd Su --until bL bm iA wX"
      COMPREPLY=($(compgen -W "$COMP_WORD" -- ${COMP_WORDS[${COMP_CWORD}]}))
  fi
}

complete -F _pigit_completion pigit
