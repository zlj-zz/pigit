#!/usr/env bash

_pigit_completion(){
  if [[ "${COMP_CWORD}" == "1" ]];then
      COMP_WORD="fm cs bs cA pc --simple ir -i lv ma Sc ia --config fr bl Cl --author -h --commit push co wM Si --pick wx --print wC --shell wD cr pA cf -f -l pt --since pull email Sd wR iD cO rm ls --until CT -c l wX -t --dry-run -v --report R id iu --count lr cR --reverse c Rm s Rx add --complete repo ca Ca ld fetch --issue t pa CO Rl iX rename sd bL user fC Ce pf --create-ignore iR wc --list cd b fu open mF cmd mS --create-config ll Ct ws bM mv SD cF --information Su f wd -p wS --version wr pp tx sl report mC Ru bc bm -r Co lc fb sp ta ix --path m ue --search Ra Rp RS -s savepd pF Rs p mt iA bd --type clear l1 --help bS fc sD cm wm"
      COMPREPLY=($(compgen -W "$COMP_WORD" -- ${COMP_WORDS[${COMP_CWORD}]}))
  fi
}

complete -F _pigit_completion pigit
